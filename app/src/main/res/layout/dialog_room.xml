<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/etRoomId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mã phòng" />

        <EditText
            android:id="@+id/etRoomName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên phòng"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etRoomPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Giá thuê"
            android:inputType="numberDecimal"
            android:layout_marginTop="8dp" />

        <CheckBox
            android:id="@+id/cbIsRented"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đã thuê"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etTenantName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Tên người thuê"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/etPhoneNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Số điện thoại"
            android:inputType="phone"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>
